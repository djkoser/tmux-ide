{
  "name": "@tmux-ide/app-electron",
  "version": "0.0.1",
  "private": true,
  "description": "tmux-ide desktop app — Electron shell with embedded daemon.",
  "type": "module",
  "main": "dist-electron/loader.cjs",
  "scripts": {
    "dev": "concurrently -n bundle,electron -c blue,green \"pnpm run dev:bundle\" \"pnpm run dev:electron\"",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "node scripts/start-electron.mjs",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "icon:build": "node scripts/build-icon.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "node-pty": "1.2.0-beta.12"
  },
  "devDependencies": {
    "@tmux-ide/daemon": "workspace:*",
    "@types/node": "^25.5.0",
    "concurrently": "^9.1.2",
    "electron": "40.9.3",
    "electron-builder": "^25.1.8",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "productName": "tmux-ide"
}
